---
interface Props {
  href: string;
  text?: string;
}

const { href, text = "Подробнее" } = Astro.props;
---

<a href={href} class="pattern-link">
  {text}
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <path d="M5 12h14M12 5l7 7-7 7"></path>
  </svg>
</a>
