---
import Layout from "../layouts/Layout.astro";
import PatternCard from "../components/PatternCard.astro";
---

<Layout>
  <section class="home-intro" aria-labelledby="home-intro-title">
    <h1 id="home-intro-title">Что такое веб-паттерны</h1>
    <p>
      Веб-паттерны это проверенные подходы к типовым задачам интерфейса: они помогают делать решения
      быстрее, понятнее и стабильнее от проекта к проекту.
    </p>
  </section>

  <section class="patterns">
    <div class="patterns-grid">
    <PatternCard
      icon="🍞"
      title="WIP: Хлебные крошки"
      description="Дополнительная навигация, которая помогает пользователям понять, где они находятся в структуре сайта."
      imageSrc="/breadcrumbs/breadcrumbs-preview.png"
      imageWidth="712px"
      imageHeight="250px"
      imageAlt="Хлебные крошки"
      href="/patterns/breadcrumbs"
    />

    <PatternCard
      icon="🎯"
      title="Универсальный фокус для интерактивных элементов"
      description="Создание функционального состояния фокуса для всех интерактивных элементов с поддержкой светлой и тёмной темы."
      imageSrc="/focus-outline/focus-outline-preview.png"
      imageWidth="712px"
      imageHeight="148px"
      imageAlt="Демонстрация универсального фокуса для интерактивных элементов"
      href="/patterns/focus-outline"
    />

    <PatternCard
      icon="📄"
      title="Центрирование страницы"
      description="Современный вариант центрирования контента на странице."
      imageSrc="/centering-page/margin-inline-preview.png"
      imageWidth="712px"
      imageHeight="219px"
      imageAlt="Демонстрация центрирования контента на странице"
      href="/patterns/centering-page"
    />
    </div>
  </section>
</Layout>
